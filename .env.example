# Copy this file to .env and fill secrets/overrides.

# Required for AI deep insights in demo checks.
# Set at least one provider key (Groq-first):
GROQ_API_KEY=replace-with-your-key
# GOOGLE_API_KEY=replace-with-your-key
# GEMINI_API_KEY=replace-with-your-key
# Optional Groq endpoint override:
# GROQ_BASE_URL=https://api.groq.com

# Optional model override.
# Leave unset to auto-select:
# - groq key -> groq:openai/gpt-oss-120b
# - google/gemini key -> google-gla:gemini-2.5-flash
# OCTOLENS_LLM_MODEL=groq:openai/gpt-oss-120b
# OCTOLENS_LLM_MODEL=google-gla:gemini-2.5-flash

# API / web defaults.
OCTOLENS_CORS_ORIGINS=http://localhost:5173
VITE_DEV_PROXY_TARGET=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000
